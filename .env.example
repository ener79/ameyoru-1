# MySQL 8.x 连接串。utf8mb4 字符集支持中文与 emoji
DATABASE_URL=mysql://mo_user:mo_password@127.0.0.1:3306/mo?charset=utf8mb4

# better-auth
BETTER_AUTH_SECRET=please-change-me-to-a-long-random-string
BETTER_AUTH_URL=http://localhost:3000

# 微信小程序(顾客端 /api/mp/*)
# AppID / AppSecret:微信公众平台「开发管理→开发设置」获取。AppSecret 仅放服务端
WX_MP_APPID=
WX_MP_SECRET=
# 顾客 token 签名密钥,必须与 BETTER_AUTH_SECRET 不同(店员/顾客体系物理隔离)
MP_JWT_SECRET=please-change-me-to-a-different-long-random-string

# 仅 scripts/migrate-sqlite-to-mysql.ts 使用。指向旧 SQLite 文件
LEGACY_SQLITE_PATH=./data/mo.db
